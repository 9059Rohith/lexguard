# Never bake secrets into the image
.env

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/

# Virtual environments
.venv/
venv/
env/

# User uploads (mounted at runtime)
uploads/*
!uploads/.gitkeep

# Test / dev files
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
tests/

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/

# SQLite database (mounted as volume or created fresh)
*.db
*.db-shm
*.db-wal

# Logs
*.log
